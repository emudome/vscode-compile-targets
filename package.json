{
  "name": "compile-targets-explorer",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "emudome",
  "repository": {
    "type": "git",
    "url": "https://github.com/emudome/vscode-compile-targets.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/compile_commands.json",
    "workspaceContains:.clangd",
    "workspaceContains:CMakePresets.json",
    "workspaceContains:CMakeLists.txt"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "compileTargetsExplorer.showHeaders": {
          "type": "boolean",
          "default": true,
          "description": "%config.showHeaders.description%"
        },
        "compileTargetsExplorer.excludePatterns": {
          "type": "array",
          "default": [],
          "items": { "type": "string" },
          "description": "%config.excludePatterns.description%"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "compileTargetsExplorer",
          "name": "%view.compileTargets.name%",
          "when": "compileTargetsExplorer.active"
        }
      ]
    },
    "commands": [
      {
        "command": "compileTargetsExplorer.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)",
        "category": "%command.category%"
      },
      {
        "command": "compileTargetsExplorer.openFile",
        "title": "%command.openFile.title%"
      },
      {
        "command": "compileTargetsExplorer.searchInTargets",
        "title": "%command.searchInTargets.title%",
        "icon": "$(search)",
        "category": "%command.category%"
      },
      {
        "command": "compileTargetsExplorer.openToSide",
        "title": "%command.openToSide.title%"
      },
      {
        "command": "compileTargetsExplorer.copyPath",
        "title": "%command.copyPath.title%"
      },
      {
        "command": "compileTargetsExplorer.copyRelativePath",
        "title": "%command.copyRelativePath.title%"
      },
      {
        "command": "compileTargetsExplorer.revealInOS",
        "title": "%command.revealInOS.title%"
      },
      {
        "command": "compileTargetsExplorer.openInTerminal",
        "title": "%command.openInTerminal.title%"
      },
      {
        "command": "compileTargetsExplorer.findInFolder",
        "title": "%command.findInFolder.title%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "compileTargetsExplorer.searchInTargets",
          "when": "view == compileTargetsExplorer",
          "group": "navigation"
        },
        {
          "command": "compileTargetsExplorer.refresh",
          "when": "view == compileTargetsExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "compileTargetsExplorer.openFile",
          "when": "view == compileTargetsExplorer && viewItem == file",
          "group": "navigation@1"
        },
        {
          "command": "compileTargetsExplorer.openToSide",
          "when": "view == compileTargetsExplorer && viewItem == file",
          "group": "navigation@2"
        },
        {
          "command": "compileTargetsExplorer.copyPath",
          "when": "view == compileTargetsExplorer && viewItem == file",
          "group": "6_copypath@1"
        },
        {
          "command": "compileTargetsExplorer.copyRelativePath",
          "when": "view == compileTargetsExplorer && viewItem == file",
          "group": "6_copypath@2"
        },
        {
          "command": "compileTargetsExplorer.revealInOS",
          "when": "view == compileTargetsExplorer && viewItem == file",
          "group": "7_reveal@1"
        },
        {
          "command": "compileTargetsExplorer.openInTerminal",
          "when": "view == compileTargetsExplorer && viewItem == file",
          "group": "7_reveal@2"
        },
        {
          "command": "compileTargetsExplorer.findInFolder",
          "when": "view == compileTargetsExplorer && viewItem == folder",
          "group": "4_search@1"
        },
        {
          "command": "compileTargetsExplorer.copyPath",
          "when": "view == compileTargetsExplorer && viewItem == folder",
          "group": "6_copypath@1"
        },
        {
          "command": "compileTargetsExplorer.copyRelativePath",
          "when": "view == compileTargetsExplorer && viewItem == folder",
          "group": "6_copypath@2"
        },
        {
          "command": "compileTargetsExplorer.revealInOS",
          "when": "view == compileTargetsExplorer && viewItem == folder",
          "group": "7_reveal@1"
        },
        {
          "command": "compileTargetsExplorer.openInTerminal",
          "when": "view == compileTargetsExplorer && viewItem == folder",
          "group": "7_reveal@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "compileTargetsExplorer.openToSide",
        "key": "ctrl+enter",
        "when": "focusedView == compileTargetsExplorer && listFocus"
      },
      {
        "command": "compileTargetsExplorer.copyPath",
        "key": "shift+alt+c",
        "when": "focusedView == compileTargetsExplorer && listFocus"
      },
      {
        "command": "compileTargetsExplorer.copyRelativePath",
        "key": "ctrl+k ctrl+shift+c",
        "when": "focusedView == compileTargetsExplorer && listFocus"
      },
      {
        "command": "compileTargetsExplorer.revealInOS",
        "key": "shift+alt+r",
        "when": "focusedView == compileTargetsExplorer && listFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/picomatch": "^4.0.2",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "picomatch": "^4.0.3"
  }
}

{
  "name": "cmake-compile-explorer",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "cmakeCompileExplorer.compileCommandsDir": {
          "type": "string",
          "default": "build",
          "description": "%config.compileCommandsDir.description%"
        },
        "cmakeCompileExplorer.showHeaders": {
          "type": "boolean",
          "default": true,
          "description": "%config.showHeaders.description%"
        },
        "cmakeCompileExplorer.headerExtensions": {
          "type": "array",
          "default": [".h", ".hpp", ".hxx", ".hh"],
          "items": { "type": "string" },
          "description": "%config.headerExtensions.description%"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "cmakeCompileExplorer",
          "name": "%view.compileTargets.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "cmakeCompileExplorer.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)",
        "category": "%command.category%"
      },
      {
        "command": "cmakeCompileExplorer.openFile",
        "title": "%command.openFile.title%"
      },
      {
        "command": "cmakeCompileExplorer.searchInTargets",
        "title": "%command.searchInTargets.title%",
        "icon": "$(search)",
        "category": "%command.category%"
      },
      {
        "command": "cmakeCompileExplorer.openToSide",
        "title": "%command.openToSide.title%"
      },
      {
        "command": "cmakeCompileExplorer.copyPath",
        "title": "%command.copyPath.title%"
      },
      {
        "command": "cmakeCompileExplorer.copyRelativePath",
        "title": "%command.copyRelativePath.title%"
      },
      {
        "command": "cmakeCompileExplorer.revealInOS",
        "title": "%command.revealInOS.title%"
      },
      {
        "command": "cmakeCompileExplorer.openInTerminal",
        "title": "%command.openInTerminal.title%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cmakeCompileExplorer.searchInTargets",
          "when": "view == cmakeCompileExplorer",
          "group": "navigation"
        },
        {
          "command": "cmakeCompileExplorer.refresh",
          "when": "view == cmakeCompileExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cmakeCompileExplorer.openFile",
          "when": "view == cmakeCompileExplorer && viewItem == file",
          "group": "navigation@1"
        },
        {
          "command": "cmakeCompileExplorer.openToSide",
          "when": "view == cmakeCompileExplorer && viewItem == file",
          "group": "navigation@2"
        },
        {
          "command": "cmakeCompileExplorer.copyPath",
          "when": "view == cmakeCompileExplorer && viewItem == file",
          "group": "6_copypath@1"
        },
        {
          "command": "cmakeCompileExplorer.copyRelativePath",
          "when": "view == cmakeCompileExplorer && viewItem == file",
          "group": "6_copypath@2"
        },
        {
          "command": "cmakeCompileExplorer.revealInOS",
          "when": "view == cmakeCompileExplorer && viewItem == file",
          "group": "7_reveal@1"
        },
        {
          "command": "cmakeCompileExplorer.openInTerminal",
          "when": "view == cmakeCompileExplorer && viewItem == file",
          "group": "7_reveal@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cmakeCompileExplorer.openToSide",
        "key": "ctrl+enter",
        "when": "focusedView == cmakeCompileExplorer && listFocus"
      },
      {
        "command": "cmakeCompileExplorer.copyPath",
        "key": "shift+alt+c",
        "when": "focusedView == cmakeCompileExplorer && listFocus"
      },
      {
        "command": "cmakeCompileExplorer.copyRelativePath",
        "key": "ctrl+k ctrl+shift+c",
        "when": "focusedView == cmakeCompileExplorer && listFocus"
      },
      {
        "command": "cmakeCompileExplorer.revealInOS",
        "key": "shift+alt+r",
        "when": "focusedView == cmakeCompileExplorer && listFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.9.3"
  }
}
